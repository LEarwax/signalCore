# PostgreSQL (used by Docker Compose — matches docker-compose.yml defaults)
POSTGRES_USER=signalcore
POSTGRES_PASSWORD=signalcore
POSTGRES_DB=signalcore

# Auth0
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_AUDIENCE=https://api.signalcore.io
AUTH0_CLIENT_ID=your_client_id
AUTH0_CLIENT_SECRET=your_client_secret
AUTH0_SECRET=a-long-random-secret-for-session-encryption

# AWS S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=signalcore-dev

# App URLs
WEB_URL=http://localhost:3000
API_URL=http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000
